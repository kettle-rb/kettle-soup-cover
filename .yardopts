--plugin timekeeper
--plugin fence
-e yard/fence/hoist.rb
--plugin yaml
--plugin junk
--plugin relative_markdown_links
--readme tmp/yard-fence/README.md
--readme README.md
--charset utf-8
--markup markdown
--markup-provider kramdown
--output docs
--load .yard_gfm_support.rb
'lib/**/*.rb'
-
'*.md'
'*.txt'
'tmp/yard-fence/*.md'
'tmp/yard-fence/*.txt'
